datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id    Int    @id @default(autoincrement())
  name  String
  email String @unique
  tasks Task[]
}

model Board {
  id    Int    @id @default(autoincrement())
  title String
  tasks Task[]
}

model Task {
  id      Int    @id @default(autoincrement())
  title   String
  status  String // Например: OPEN, IN_PROGRESS, DONE
  userId  Int
  user    User   @relation(fields: [userId], references: [id])
  boardId Int
  board   Board  @relation(fields: [boardId], references: [id])
}